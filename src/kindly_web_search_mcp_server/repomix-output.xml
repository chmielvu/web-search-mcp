from __future__ import annotations

import re
from typing import Literal

from pydantic import BaseModel, Field

from .normalize import normalize_query

SearchIntent = Literal[
    "factual",
    "navigational",
    "troubleshooting",
    "comparative",
    "multi_hop",
    "freshness_sensitive",
]
RewriteMode = Literal["bypass", "light_rewrite", "multi_rewrite", "decompose"]

_SEARCH_OPERATORS = (
    "site:",
    "filetype:",
    "inurl:",
    "intitle:",
    "repo:",
    "path:",
    "is:",
    "after:",
    "before:",
    "language:",
)

_EXACT_TOKEN_PATTERNS = (
    re.compile(r"https?://", re.IGNORECASE),
    re.compile(r"\bwww\.", re.IGNORECASE),
    re.compile(r'["`][^"`]{4,}["`]'),
    re.compile(r"\b[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+\b"),
    re.compile(r"/[A-Za-z0-9_.-]+(?:/[A-Za-z0-9_.-]+)+"),
    re.compile(r"\b\d+(?:\.\d+){1,3}\b"),
)

_TRIAGE_HINTS = {
    "troubleshooting": ("error", "exception", "traceback", "stack trace", "failed", "cannot", "undefined"),
    "comparative": (" vs ", "compare", "alternatives", "best ", "better ", "tradeoff", "trade-off"),
    "freshness_sensitive": ("latest", "today", "current", "recent", "release", "changelog", "2024", "2025", "2026"),
    "multi_hop": (" and ", " or ", " plus ", " with ", " for ", " guide ", " tutorial "),
}


class RewritePolicy(BaseModel):
    mode: RewriteMode
    reason: str
    must_keep_terms: list[str] = Field(default_factory=list)
    include_original: bool = True


class QueryRouting(BaseModel):
    intent: SearchIntent
    policy: RewritePolicy


def _extract_must_keep_terms(query: str) -> list[str]:
    terms: list[str] = []
    terms.extend(match.group(1) for match in re.finditer(r'"([^"]+)"', query) if match.group(1))
    terms.extend(match.group(1) for match in re.finditer(r"`([^`]+)`", query) if match.group(1))

    for operator in _SEARCH_OPERATORS:
        if operator in query:
            terms.append(operator.rstrip(":"))

    for pattern in _EXACT_TOKEN_PATTERNS:
        for match in pattern.finditer(query):
            terms.append(match.group(0))

    seen: set[str] = set()
    out: list[str] = []
    for term in terms:
        normalized = normalize_query(term)
        if normalized and normalized.casefold() not in seen:
            seen.add(normalized.casefold())
            out.append(normalized)
    return out


def _detect_intent(query: str) -> SearchIntent:
    lower = f" {query.casefold()} "

    if any(token in lower for token in _TRIAGE_HINTS["comparative"]):
        return "comparative"
    if any(token in lower for token in _TRIAGE_HINTS["freshness_sensitive"]):
        return "freshness_sensitive"
    if any(token in lower for token in _TRIAGE_HINTS["troubleshooting"]):
        return "troubleshooting"
    if any(token in lower for token in _TRIAGE_HINTS["multi_hop"]):
        return "multi_hop"
    if any(op in query for op in _SEARCH_OPERATORS):
        return "navigational"
    return "factual"


def classify_search_query(query: str) -> QueryRouting:
    normalized = normalize_query(query)
    intent = _detect_intent(normalized)
    must_keep_terms = _extract_must_keep_terms(normalized)
    operator_rich = sum(1 for operator in _SEARCH_OPERATORS if operator in normalized) >= 2
    exact_tokens = any(pattern.search(normalized) for pattern in _EXACT_TOKEN_PATTERNS)
    quoted_text = '"' in normalized or "`" in normalized
    high_precision = operator_rich or exact_tokens or quoted_text

    if high_precision:
        return QueryRouting(
            intent=intent,
            policy=RewritePolicy(
                mode="bypass",
                reason="Query contains exact tokens or search operators that should be preserved verbatim.",
                must_keep_terms=must_keep_terms,
                include_original=True,
            ),
        )

    if intent in {"comparative", "multi_hop", "freshness_sensitive"}:
        mode: RewriteMode = "multi_rewrite"
        reason = "Query is broad enough to benefit from multiple complementary search lanes."
    elif intent == "troubleshooting":
        mode = "light_rewrite"
        reason = "Troubleshooting queries usually benefit from one cleaned variant plus the original."
    else:
        mode = "light_rewrite"
        reason = "Query is a normal lookup and should be gently rewritten."

    return QueryRouting(
        intent=intent,
        policy=RewritePolicy(
            mode=mode,
            reason=reason,
            must_keep_terms=must_keep_terms,
            include_original=True,
        ),
    )
