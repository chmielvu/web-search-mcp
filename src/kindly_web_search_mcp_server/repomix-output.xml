<file path="search/gemini_provider_grounding.py">
"""Gemini grounding helpers for the `web_search` provider mix.

This path is intentionally separate from the `gemini_search` MCP tool. The MCP
tool is answer-oriented and returns a grounded synthesis. The provider helper
below is search-oriented and produces lightweight `WebSearchResult` objects that
fit the shared merge/rerank pipeline.
"""

from __future__ import annotations

import asyncio
import re
from collections import defaultdict
from typing import Any
from urllib.parse import urlparse

import httpx
from google.genai import types

from ..models import WebSearchResult
from ..settings import settings
from .gemini_grounding import get_gemini_client

PROVIDER_SEARCH_SYSTEM_PROMPT = """
You are curating lightweight web search hits for an agentic search tool.

Rules:
- Use Google Search grounding.
- Do not write a narrative answer or summary paragraph.
- Surface the most useful and distinct web sources for the query.
- Prefer official docs, canonical vendor pages, project repos, standards, and high-signal technical references when relevant.
- Emit short factual sentences that describe why each source is relevant.
- Keep each sentence self-contained, concrete, and tightly grounded in source text.
- Avoid filler, hedging, and repetition.
""".strip()

PROVIDER_SEARCH_PROMPT_TEMPLATE = """
Search query: {query}
Target results: {num_results}

Use Google Search grounding to find the best web sources for this query.
Write a compact evidence digest with one short sentence per promising source.
Keep each sentence under 220 characters and grounded in a specific source when possible.
No intro. No outro. No markdown table.
""".strip()

_DEFAULT_SNIPPET_TEMPLATE = "Google-grounded result relevant to: {query}"
_MAX_SNIPPET_CHARS = 240
_TITLE_TAG_RE = re.compile(r"<title>(.*?)</title>", re.IGNORECASE | re.DOTALL)


def _normalize_snippet(text: str) -> str:
    cleaned = " ".join(text.split())
    if len(cleaned) <= _MAX_SNIPPET_CHARS:
        return cleaned
    return cleaned[: _MAX_SNIPPET_CHARS - 1].rstrip() + "…"


def _extract_text_parts(response: Any) -> str:
    candidates = getattr(response, "candidates", None) or []
    if not candidates:
        return ""
    parts = getattr(getattr(candidates[0], "content", None), "parts", None) or []
    return "\n".join(
        part.text
        for part in parts
        if not getattr(part, "thought", False) and getattr(part, "text", None)
    )


def _is_generic_title(title: str) -> bool:
    normalized = title.strip().lower()
    if not normalized:
        return True
    if " " not in normalized:
        return True
    hostname = normalized.removeprefix("www.")
    return "." in hostname and hostname.count(" ") == 0


def _extract_html_title(html: str) -> str | None:
    match = _TITLE_TAG_RE.search(html)
    if not match:
        return None
    title = " ".join(match.group(1).split()).strip()
    return title or None


def _build_support_snippets(response: Any) -> dict[int, str]:
    candidates = getattr(response, "candidates", None) or []
    if not candidates:
        return {}

    metadata = getattr(candidates[0], "grounding_metadata", None)
    if not metadata:
        return {}

    grouped_segments: dict[int, list[str]] = defaultdict(list)
    for support in getattr(metadata, "grounding_supports", None) or []:
        segment = getattr(getattr(support, "segment", None), "text", "") or ""
        if not segment.strip():
            continue
        for chunk_index in getattr(support, "grounding_chunk_indices", None) or []:
            if segment not in grouped_segments[chunk_index]:
                grouped_segments[chunk_index].append(segment)

    return {
        chunk_index: _normalize_snippet(" ".join(segments))
        for chunk_index, segments in grouped_segments.items()
        if segments
    }


async def _resolve_redirect_result(result: WebSearchResult) -> WebSearchResult:
    parsed = urlparse(result.link)
    if parsed.netloc != "vertexaisearch.cloud.google.com":
        return result

    try:
        async with httpx.AsyncClient(follow_redirects=True, timeout=10) as client:
            response = await client.get(result.link)
        updated: dict[str, str] = {"link": str(response.url)}
        if _is_generic_title(result.title):
            html_title = _extract_html_title(response.text)
            if html_title:
                updated["title"] = html_title
        return result.model_copy(update=updated)
    except Exception:
        return result


def build_grounded_search_results(
    response: Any,
    *,
    query: str,
    num_results: int,
) -> list[WebSearchResult]:
    """Convert Gemini grounding metadata into lightweight search hits."""
    candidates = getattr(response, "candidates", None) or []
    if not candidates:
        return []

    metadata = getattr(candidates[0], "grounding_metadata", None)
    if not metadata:
        return []

    fallback_answer = _normalize_snippet(_extract_text_parts(response))
    support_snippets = _build_support_snippets(response)
    grounding_chunks = getattr(metadata, "grounding_chunks", None) or []

    results: list[WebSearchResult] = []
    for index, chunk in enumerate(grounding_chunks):
        web = getattr(chunk, "web", None)
        url = getattr(web, "uri", None) if web else None
        title = getattr(web, "title", None) if web else None
        if not url or not title:
            continue

        snippet = support_snippets.get(index)
        if not snippet and fallback_answer:
            snippet = fallback_answer
        if not snippet:
            snippet = _DEFAULT_SNIPPET_TEMPLATE.format(query=query)

        results.append(
            WebSearchResult(
                title=title,
                link=url,
                snippet=snippet,
                providers=["gemini"],
            )
        )
        if len(results) >= num_results:
            break

    return results


async def grounded_provider_search(
    query: str,
    *,
    num_results: int,
) -> list[WebSearchResult]:
    """Run Gemini grounding as a search-style provider."""
    client = get_gemini_client()
    if not client:
        return []

    prompt = PROVIDER_SEARCH_PROMPT_TEMPLATE.format(query=query, num_results=num_results)
    config = types.GenerateContentConfig(
        system_instruction=PROVIDER_SEARCH_SYSTEM_PROMPT,
        tools=[types.Tool(google_search=types.GoogleSearch())],
        temperature=0.1,
    )

    response = await asyncio.to_thread(
        client.models.generate_content,
        model=settings.gemini_grounding_model,
        contents=prompt,
        config=config,
    )
    results = build_grounded_search_results(response, query=query, num_results=num_results)
    return [await _resolve_redirect_result(result) for result in results]
