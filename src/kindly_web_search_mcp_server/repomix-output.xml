"""HF Space reranker using jinaai/jina-reranker-v1-turbo-en model."""

from __future__ import annotations

import logging

import httpx
from pydantic import BaseModel, Field

logger = logging.getLogger(__name__)


class RerankItem(BaseModel):
    """Single rerank result with score."""

    document: str = Field(description="The document text")
    relevance_score: float = Field(description="Relevance score from reranker")
    index: int = Field(description="Original index of the document")


async def hf_space_rerank(
    query: str,
    documents: list[str],
    timeout: float = 30.0,
) -> list[tuple[int, float]]:
    """
    Rerank documents using HF Space endpoint.

    Endpoint: https://chmielvu-Fast_Text-BM25-Rerank.hf.space/v1/rerank
    Model: jinaai/jina-reranker-v1-turbo-en

    Args:
        query: Search query
        documents: List of document strings to rerank
        timeout: Request timeout in seconds

    Returns:
        List of (index, score) tuples sorted by relevance (highest first)
        Falls back to original order on failure
    """
    if not documents:
        return []

    endpoint = "https://chmielvu-Fast_Text-BM25-Rerank.hf.space/v1/rerank"

    try:
        async with httpx.AsyncClient(timeout=timeout) as client:
            response = await client.post(
                endpoint,
                json={
                    "query": query,
                    "documents": documents,
                },
            )
            response.raise_for_status()

            data = response.json()

            # Parse response - expected format: ranked documents with scores
            if isinstance(data, list):
                # Assume list of items with relevance_score
                ranked = []
                for item in data:
                    doc = item.get("document", "")
                    score = item.get("relevance_score", 0.0)
                    # Find original index
                    try:
                        original_index = documents.index(doc)
                        ranked.append((original_index, score))
                    except ValueError:
                        # Document not found in original list
                        continue
                return ranked

            elif isinstance(data, dict) and "results" in data:
                # Assume dict with results array
                ranked = []
                for item in data["results"]:
                    doc = item.get("document", "")
                    score = item.get("relevance_score", item.get("score", 0.0))
                    try:
                        original_index = documents.index(doc)
                        ranked.append((original_index, score))
                    except ValueError:
                        continue
                return ranked

            # Unknown format, fall back to original order
            logger.warning(f"Unexpected response format from HF Space: {data}")
            return list(enumerate([0.0] * len(documents)))

    except httpx.TimeoutException:
        logger.warning(f"HF Space reranking timeout for query: {query[:50]}")
        return list(enumerate([0.0] * len(documents)))

    except httpx.HTTPStatusError as e:
        logger.warning(f"HF Space HTTP error: {e.response.status_code}")
        return list(enumerate([0.0] * len(documents)))

    except Exception as e:
        logger.warning(f"HF Space reranking failed: {e}")
        # Fallback: return original order with zero scores
        return list(enumerate([0.0] * len(documents)))
