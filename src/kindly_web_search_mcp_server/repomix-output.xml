"""HF Space embeddings using jina-embeddings-v2-small-en model."""

from __future__ import annotations

import logging
from typing import Any

import httpx

logger = logging.getLogger(__name__)

# HF Space endpoint for embeddings
EMBEDDINGS_ENDPOINT = "https://chmielvu-Fast_Text-BM25-Rerank.hf.space/v1/embeddings"

# Model name as expected by the HF Space
MODEL_NAME = "code-embed"

# Embedding dimension for jina-embeddings-v2-small-en
EMBEDDING_DIM = 512


async def embed_texts(
    texts: list[str],
    *,
    timeout: float = 30.0,
    http_client: httpx.AsyncClient | None = None,
) -> list[list[float]]:
    """
    Generate embeddings for multiple texts using HF Space endpoint.

    Args:
        texts: List of text strings to embed
        timeout: Request timeout in seconds (default 30s)
        http_client: Optional httpx AsyncClient to reuse

    Returns:
        List of embedding vectors (each is a list of 512 floats)
        Falls back to zero vectors on failure (never crashes)

    Example:
        >>> embeddings = await embed_texts(["hello world", "test"])
        >>> len(embeddings)
        2
        >>> len(embeddings[0])
        512
    """
    if not texts:
        return []

    # Filter out empty/whitespace-only texts
    valid_texts = [t.strip() for t in texts if t.strip()]

    if not valid_texts:
        # All texts were empty, return zero vectors for each input
        return [[0.0] * EMBEDDING_DIM for _ in texts]

    try:
        async def _do_request(client: httpx.AsyncClient) -> dict[str, Any]:
            payload = {
                "input": valid_texts,
                "model": MODEL_NAME,
            }
            response = await client.post(EMBEDDINGS_ENDPOINT, json=payload)
            response.raise_for_status()
            data = response.json()

            if not isinstance(data, dict):
                raise ValueError(f"Expected dict response, got {type(data).__name__}")

            return data

        if http_client is None:
            async with httpx.AsyncClient(timeout=timeout) as client:
                data = await _do_request(client)
        else:
            data = await _do_request(http_client)

        # Parse response - expected format: {"data": [{"embedding": [...]}]}
        embeddings_list = data.get("data", [])

        if not isinstance(embeddings_list, list):
            raise ValueError(f"Expected 'data' to be list, got {type(embeddings_list).__name__}")

        if len(embeddings_list) != len(valid_texts):
            logger.warning(
                f"HF Space returned {len(embeddings_list)} embeddings "
                f"for {len(valid_texts)} texts"
            )

        # Extract embeddings and validate dimensions
        result_embeddings: list[list[float]] = []
        for i, item in enumerate(embeddings_list):
            if not isinstance(item, dict):
                logger.warning(f"Invalid embedding item at index {i}: not a dict")
                result_embeddings.append([0.0] * EMBEDDING_DIM)
                continue

            embedding = item.get("embedding")

            if not isinstance(embedding, list):
                logger.warning(f"Invalid embedding at index {i}: 'embedding' not a list")
                result_embeddings.append([0.0] * EMBEDDING_DIM)
                continue

            if len(embedding) != EMBEDDING_DIM:
                logger.warning(
                    f"Invalid embedding at index {i}: "
                    f"expected {EMBEDDING_DIM} dims, got {len(embedding)}"
                )
                result_embeddings.append([0.0] * EMBEDDING_DIM)
                continue

            # Validate all values are floats
            try:
                result_embeddings.append([float(v) for v in embedding])
            except (ValueError, TypeError):
                logger.warning(f"Invalid embedding at index {i}: non-float values")
                result_embeddings.append([0.0] * EMBEDDING_DIM)

        # Map back to original input order (handle empty texts)
        final_result: list[list[float]] = []
        valid_index = 0
        for text in texts:
            if text.strip():
                if valid_index < len(result_embeddings):
                    final_result.append(result_embeddings[valid_index])
                    valid_index += 1
                else:
                    final_result.append([0.0] * EMBEDDING_DIM)
            else:
                # Empty text, return zero vector
                final_result.append([0.0] * EMBEDDING_DIM)

        return final_result

    except httpx.TimeoutException:
        logger.warning(f"HF Space embeddings timeout for {len(texts)} texts")
        return [[0.0] * EMBEDDING_DIM for _ in texts]

    except httpx.HTTPStatusError as e:
        logger.warning(f"HF Space HTTP error: {e.response.status_code}")
        return [[0.0] * EMBEDDING_DIM for _ in texts]

    except Exception as e:
        logger.warning(f"HF Space embeddings failed: {e}")
        # Fallback: return zero vectors for all texts
        return [[0.0] * EMBEDDING_DIM for _ in texts]


async def embed_query(
    query: str,
    *,
    timeout: float = 30.0,
    http_client: httpx.AsyncClient | None = None,
) -> list[float]:
    """
    Generate embedding for a single query text.

    Args:
        query: Query string to embed
        timeout: Request timeout in seconds (default 30s)
        http_client: Optional httpx AsyncClient to reuse

    Returns:
        Single embedding vector (list of 512 floats)
        Falls back to zero vector on failure

    Example:
        >>> embedding = await embed_query("search query")
        >>> len(embedding)
        512
    """
    if not query.strip():
        return [0.0] * EMBEDDING_DIM

    embeddings = await embed_texts([query], timeout=timeout, http_client=http_client)
    return embeddings[0] if embeddings else [0.0] * EMBEDDING_DIM
