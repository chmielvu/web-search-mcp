{
  "title": "Kindly MCP - Provider Health & Latency",
  "uid": "kindly-mcp-providers-v1",
  "version": 1,
  "tags": ["kindly", "mcp", "providers", "otel"],
  "schemaVersion": 41,
  "refresh": "1m",
  "time": { "from": "now-3h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "constant",
        "query": "web-search-mcp"
      },
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Provider Call Rate by Provider",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (provider_name) (rate(web_search_provider_calls_total{service_name=\"$service\"}[2m]))",
          "legendFormat": "{{provider_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Provider p95 Latency",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider_name) (rate(web_search_provider_duration_seconds_bucket{service_name=\"$service\"}[5m])))",
          "legendFormat": "p95 {{provider_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Provider Success % (5m)",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (provider_name) (rate(web_search_provider_calls_total{service_name=\"$service\", provider_status=\"success\"}[5m])) / sum by (provider_name) (rate(web_search_provider_calls_total{service_name=\"$service\"}[5m]))",
          "refId": "A",
          "legendFormat": "{{provider_name}}"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["mean"] } },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.8,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.92 },
              { "color": "green", "value": 0.98 }
            ]
          }
        }
      }
    }
  ]
}
