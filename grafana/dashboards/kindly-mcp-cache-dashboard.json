{
  "title": "Kindly MCP - Cache Effectiveness & Semantic Performance",
  "uid": "kindly-mcp-cache-v1",
  "version": 1,
  "tags": ["kindly", "mcp", "cache", "semantic", "lancedb", "otel"],
  "schemaVersion": 41,
  "refresh": "1m",
  "time": { "from": "now-12h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "constant",
        "query": "web-search-mcp"
      },
      {
        "name": "datasource",
        "type": "datasource",
        "pluginId": "prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Overall Cache Hit Rate (5m)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(web_search_cache_requests_total{service_name=\"$service\", cache_hit=\"true\"}[5m])) / sum(rate(web_search_cache_requests_total{service_name=\"$service\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.65 },
              { "color": "green", "value": 0.82 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Semantic Cache Hit Rate",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(web_search_cache_requests_total{service_name=\"$service\", cache_type=\"semantic\", cache_hit=\"true\"}[5m])) / sum(rate(web_search_cache_requests_total{service_name=\"$service\", cache_type=\"semantic\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0.5,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.55 },
              { "color": "green", "value": 0.75 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Cache Hit Rate by Type",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 5 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (cache_type) (rate(web_search_cache_requests_total{service_name=\"$service\", cache_hit=\"true\"}[2m])) / sum by (cache_type) (rate(web_search_cache_requests_total{service_name=\"$service\"}[2m]))",
          "legendFormat": "{{cache_type}} hit rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 4,
      "type": "heatmap",
      "title": "Semantic Similarity Score Distribution (on hit)",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (le) (rate(web_search_semantic_cache_score_distribution_bucket{service_name=\"$service\", cache_hit=\"true\"}[5m]))",
          "format": "heatmap",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Cache Lookup Duration (p95 by type)",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, cache_type) (rate(web_search_cache_duration_seconds_bucket{service_name=\"$service\"}[5m])))",
          "legendFormat": "p95 {{cache_type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ]
}
